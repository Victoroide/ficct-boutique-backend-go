@startuml
' Embedded standalone style block (replicated per file; standalone)
skinparam shadowing false
skinparam backgroundColor White
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam monochrome true
skinparam style strictuml
skinparam nodesep 50
skinparam ranksep 60
skinparam padding 3
skinparam classAttributeIconSize 0
hide circle
skinparam linetype ortho

top to bottom direction

package "MS1 Go Core (Boundary)" {
  class "GraphQL /graphql\n(schema.graphqls)" as GraphQL <<Boundary>> {
    +login(input: LoginInput!): AuthPayload!
  }
  class "Resolver.Login\n(mutations.go)" as LoginResolver <<Boundary>> {
    +Login(ctx, args{Input{Email, Password}}): AuthPayloadResolver
    -returns token + expiresAt + user
  }
}

package "MS1 Go Core (Control)" {
  class AuthService <<Control>> {
    +Login(ctx, email, password): AuthResult
    -reject if !IsActive (ErrInactiveUser)
    -reject bad password (ErrInvalidCredentials)
    -calls VerifyPassword + IssueAccess
  }
  class TokenIssuer <<Control>> {
    -accessTTL : Duration
    +IssueAccess(userID, email, role, branchID): (string, time, error)
    -sign RS256 with role + email claim, kid header
  }
  class PasswordHasher <<Control>> {
    +HashPassword(password): string
    +VerifyPassword(password, encoded): bool
    -Argon2id m=64MiB,t=3,p=2 (constant-time compare)
  }
}

package "MS1 Go Core (Entity / Repository)" {
  class UserRepo <<Entity>> {
    +FindByEmail(ctx, email): User
    +FindByID(ctx, id): User
    +Create(ctx, email, hash, fullName, role): User
  }
  class User <<Entity>> {
    +ID : UUID
    +Email : string (unique, lowercased)
    +PasswordHash : string (argon2id)
    +Role : admin|staff|customer|system
    +IsActive : bool
  }
  class Claims <<Entity>> {
    +Role : Role
    +Email : string
    +BranchID : UUID 0..1
    +RegisteredClaims (iss, sub, aud, exp)
  }
  class KeyPair <<Entity>> {
    +Private : rsa.PrivateKey
    +Public : rsa.PublicKey
    +KeyID : string (kid)
  }
}

class "NeonDB (PostgreSQL)" as DB <<Datastore>>

GraphQL --> LoginResolver : login
LoginResolver --> AuthService : Login
AuthService --> "0..*" UserRepo
AuthService --> "1" TokenIssuer
AuthService ..> PasswordHasher : VerifyPassword
UserRepo --> "0..*" User
UserRepo --> DB
TokenIssuer ..> Claims : build (RS256)
TokenIssuer o-- "1" KeyPair

@enduml