@startuml
' Embedded standalone style block (replicated per file; standalone)
skinparam shadowing false
skinparam backgroundColor White
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam monochrome true
skinparam style strictuml
skinparam nodesep 50
skinparam ranksep 60
skinparam padding 3
skinparam classAttributeIconSize 0
hide circle

|Personal Logistico / Administrador|
start
:Abrir modulo de inventario\n(Angular Admin);

if (operacion?) then (consultar existencias)
  |Angular Admin\n(inventory)|
  :Solicitar query inventoryEntries\n(filter sucursal / bajo stock,\nlimit, offset) (POST /graphql via Apollo);
  |Go inventory resolvers\n(mutations.go / resolvers)|
  :requireAuth\n(admin / staff);
  |Go InventoryRepo\n(inventory.go)|
  :SearchInventory(filter)\nsobre SC-01 / SC-02;
  |NeonDB (PostgreSQL)|
  :SELECT inventory\n(quantity, reorder_level, updated_at);
  |Go inventory resolvers\n(mutations.go / resolvers)|
  :Evaluar bajo stock\n(quantity <= reorder_level);
  |Angular Admin\n(inventory)|
  :Mostrar stock por sucursal\ny resaltar alertas de reposicion;
  |Personal Logistico / Administrador|
  stop
else (ajustar stock / punto de reorden)
  |Personal Logistico / Administrador|
  :Seleccionar variante y sucursal\n(SC-01 o SC-02) e indicar cambio;

  |Angular Admin\n(inventory)|
  :Enviar mutation de inventario\n(setInventoryStock / adjustInventoryStock /\nupdateInventoryReorderLevel / upsertInventory);

  |Go inventory resolvers\n(mutations.go / resolvers)|
  if (rol admin / staff? (requireAuth)) then (no)
    :Rechazar operacion\n(no autorizado);
    |Angular Admin\n(inventory)|
    :Mostrar error de permisos;
    |Personal Logistico / Administrador|
    stop
  else (si)
    :Validar entrada y enrutar mutation;

    |Go InventoryRepo\n(inventory.go)|
    if (tipo de operacion?) then (setInventoryStock)
      :SetStock(variant, branch, quantity)\ncantidad absoluta;
    elseif (adjustInventoryStock) then
      :AdjustStock(variant, branch, delta)\nno baja de cero;
    elseif (updateInventoryReorderLevel) then
      :SetReorderLevel(variant, branch, level);
    else (upsertInventory)
      :Upsert(variant, branch,\nquantity, reorderLevel);
    endif

    |NeonDB (PostgreSQL)|
    if (escritura exitosa?) then (no)
      :Devolver error de persistencia\n(p.ej. delta dejaria stock negativo);
      |Angular Admin\n(inventory)|
      :Mostrar error al usuario;
      |Personal Logistico / Administrador|
      stop
    else (si)
      :INSERT ON CONFLICT / UPDATE inventory\n(quantity, reorder_level, updated_at);
    endif

    |Go inventory resolvers\n(mutations.go / resolvers)|
    :Reevaluar bajo stock\n(quantity <= reorder_level);
    :Devolver InventoryEntry + estado de reposicion;
    |Angular Admin\n(inventory)|
    :Refrescar tablero de inventario\n(alertas de reorden por sucursal);
    |Personal Logistico / Administrador|
    stop
  endif
endif
@enduml
