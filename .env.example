# Server
APP_ENV=development
APP_PORT=8080
APP_LOG_LEVEL=debug

# Database
DATABASE_URL=postgres://ficct:ficct@postgres:5432/ficct_boutique?sslmode=disable

# JWT RS256 keys (paths inside the container)
JWT_PRIVATE_KEY_PATH=/app/.tools/keys/jwt_private_dev.pem
JWT_PUBLIC_KEY_PATH=/app/.tools/keys/jwt_public_dev.pem
JWT_ISSUER=ficct-go
JWT_AUDIENCE=ficct-express,ficct-django,ficct-angular,ficct-mobile
JWT_KEY_ID=dev-1
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:19006,http://localhost:8081

# Webhook (invoice automation, e.g. n8n)
WEBHOOK_INVOICE_URL=http://host.docker.internal:5678/webhook/ficct-invoice
WEBHOOK_HMAC_SECRET=replace-with-strong-random-256-bit-secret
WEBHOOK_DISPATCH_INTERVAL_SECONDS=5
WEBHOOK_MAX_RETRIES=5

# Rate limiting
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
