# Server
APP_ENV=development
APP_PORT=8080
APP_LOG_LEVEL=debug

# Database
DATABASE_URL=postgres://ficct:ficct@postgres:5432/ficct_boutique?sslmode=disable
# Directory containing the SQL migration files (read by `cmd/migrate`).
# Defaults to "migrations" relative to the working directory if unset.
MIGRATIONS_DIR=migrations

# JWT RS256 keys for local host runs
JWT_PRIVATE_KEY_PATH=.tools/keys/jwt_private_dev.pem
JWT_PUBLIC_KEY_PATH=.tools/keys/jwt_public_dev.pem
# Optional docker-compose runtime secret mount. For external PEMs, set for example:
# FICCT_DEPLOYMENT_SECRETS_DIR=D:/Repositories/_deployment_secrets
# FICCT_DOCKER_JWT_PRIVATE_KEY_PATH=/run/secrets/ficct/jwt_private.pem
# FICCT_DOCKER_JWT_PUBLIC_KEY_PATH=/run/secrets/ficct/jwt_public.pem
JWT_ISSUER=ficct-go
JWT_AUDIENCE=ficct-express,ficct-django,ficct-angular,ficct-mobile
JWT_KEY_ID=dev-1
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:19006,http://localhost:8081

# Webhook (invoice automation, e.g. n8n)
WEBHOOK_INVOICE_URL=http://host.docker.internal:5678/webhook/ficct-invoice
WEBHOOK_HMAC_SECRET=replace-with-strong-random-256-bit-secret
WEBHOOK_DISPATCH_INTERVAL_SECONDS=5
WEBHOOK_MAX_RETRIES=5

# Rate limiting
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

# Expo Push API.
#   - Production:             https://exp.host/--/api/v2/push/send  (default)
#   - Local full-compose:     http://fake-expo-push:8080/--/api/v2/push/send
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
# Only set when "Enhanced Push Security" is enabled for the Expo project.
EXPO_PUSH_ACCESS_TOKEN=
